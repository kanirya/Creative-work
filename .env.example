# Database
DATABASE_URL=postgresql://edupilot:edupilot_password@postgres:5432/edupilot
POSTGRES_DB=edupilot
POSTGRES_USER=edupilot
POSTGRES_PASSWORD=edupilot_password

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET_KEY=your-256-bit-secret-key-here-change-in-production
JWT_ISSUER=EduPilot
JWT_AUDIENCE=EduPilot
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=edupilot-storage

# Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn-here

# Logging
LOG_LEVEL=INFO

# API Gateway
API_GATEWAY_URL=http://api-gateway:8080

# Microservices URLs
AI_AGENT_URL=http://ai-agent:8001
LMS_SCRAPER_URL=http://lms-scraper:8002
TRANSCRIPTION_URL=http://transcription:8003
SCHEDULER_URL=http://scheduler:8004

# LMS Configuration
LMS_BASE_URL=https://lms.iqra.edu.pk
LMS_LOGIN_URL=https://lms.iqra.edu.pk/login

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_TELEMETRY_DISABLED=1
