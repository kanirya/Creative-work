# Server
HOST=0.0.0.0
PORT=8004
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edupilot

# Microservice URLs
LMS_SCRAPER_URL=http://localhost:8002
TRANSCRIPTION_URL=http://localhost:8003

# Job Configuration
SCRAPING_INTERVAL_HOURS=6
TRANSCRIPTION_CHECK_INTERVAL_MINUTES=5
BACKUP_TIME=02:00
JOB_HISTORY_RETENTION_DAYS=90

# Alerting
ALERT_EMAIL=admin@edupilot.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
