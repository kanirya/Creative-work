{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=edupilot;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_SECURE_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "EduPilot.API",
    "Audience": "EduPilot.Clients",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "CorsOrigins": [
    "http://localhost:3000",
    "http://localhost:3001",
    "http://localhost:3002"
  ],
  "MicroserviceUrls": {
    "AIAgent": "http://localhost:8001",
    "LMSScraper": "http://localhost:8002",
    "Transcription": "http://localhost:8003",
    "Scheduler": "http://localhost:8004"
  },
  "CacheSettings": {
    "QueryCacheTTLMinutes": 60,
    "StudentDataCacheTTLMinutes": 360
  }
}
