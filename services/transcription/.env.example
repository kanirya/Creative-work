# Server
HOST=0.0.0.0
PORT=8003
LOG_LEVEL=info

# Whisper Configuration
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
MIN_AUDIO_SAMPLE_RATE=16000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edupilot

# OpenAI (for embeddings)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-ada-002

# Storage
AUDIO_STORAGE_PATH=/tmp/audio
