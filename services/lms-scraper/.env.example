# Server
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=info

# ── Microsoft Azure AD Credentials ──────────────────────────────────────────
# These are the student's Microsoft 365 / Iqra University credentials
# Used for OIDC login to https://lms.iqra.edu.pk
MS_EMAIL=student@iqra.edu.pk
MS_PASSWORD=your_microsoft_password_here

# ── LMS Configuration ────────────────────────────────────────────────────────
LMS_BASE_URL=https://lms.iqra.edu.pk
LMS_TIMEOUT=30000

# ── Session Persistence ──────────────────────────────────────────────────────
# Path to store Moodle session cookies (avoids re-login on every scrape)
SESSION_STORAGE_PATH=/tmp/moodle_session.json

# ── Scraping ─────────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6

# ── API Gateway ──────────────────────────────────────────────────────────────
API_GATEWAY_URL=http://localhost:5000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://edupilot:password@localhost:5432/edupilot

# ── OpenAI (for vector embeddings) ───────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
