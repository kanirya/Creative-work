# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edupilot

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Server
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info

# Vector Search
EMBEDDING_MODEL=text-embedding-ada-002
MAX_SEARCH_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# LLM
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
MAX_TOKENS=1000
